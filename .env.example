# ---------------------------------------------------------------------------
# Lumora Kiosk — environment variables
#
# Copy this file to .env.local and fill in any values you need to override.
# The kiosk works out-of-the-box with the defaults below — you only need to
# edit this file if the server runs on a non-standard address/port.
# ---------------------------------------------------------------------------

# Address of the local Lumora server (Express + Socket.IO).
# Default: http://localhost:4000
# Override if the server is on a non-standard port or a remote LAN address.
# LUMORA_SERVER_URL=http://localhost:4000

# ---------------------------------------------------------------------------
# Kiosk auto sign-in (optional)
#
# Set these to have the kiosk display automatically sign in on boot without
# showing the auth screen. The account must already exist in the local SQLite
# database (create it via POST /api/v1/auth/register first).
# ---------------------------------------------------------------------------
# REACT_APP_KIOSK_MODE=true
# REACT_APP_KIOSK_AUTO_SIGNIN=true
# REACT_APP_KIOSK_ADMIN_EMAIL=admin@home.local
# REACT_APP_KIOSK_ADMIN_PASSWORD=your-secure-password
# REACT_APP_KIOSK_HIDE_SIGNOUT=true
