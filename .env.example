# REQUIRED: Supabase Configuration
# Get these from: https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Alternative Supabase env names (used by Vercel integration)
# The vite.config.ts will use NEXT_PUBLIC_* first, then fall back to these
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# REQUIRED for Kiosk Auto Sign-In
REACT_APP_KIOSK_MODE=true
REACT_APP_KIOSK_AUTO_SIGNIN=true
REACT_APP_KIOSK_ADMIN_EMAIL=admin@household.com
REACT_APP_KIOSK_ADMIN_PASSWORD=your-secure-password

# OPTIONAL: Kiosk Settings
REACT_APP_KIOSK_HIDE_SIGNOUT=true

# NOTE: For Tauri Android:
# 1. Create a .env.local file in the project root (not committed to git)
# 2. Add all NEXT_PUBLIC_SUPABASE_* or SUPABASE_* vars with your actual values
# 3. Add REACT_APP_KIOSK_* for kiosk auto-signin
# 4. Run: npm run tauri dev
# 5. Check browser console (F12) for debug logs starting with [v0]
