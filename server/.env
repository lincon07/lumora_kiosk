LUMORA_PORT=4000

# ── Central server (lumora_central_api + lumora_central_socket_io) ──────────
# Replace with your central server's IP or domain (NOT the local hub IP)
CENTRAL_API_URL=http://YOUR_CENTRAL_SERVER_IP:4000
CENTRAL_SOCKET_URL=http://YOUR_CENTRAL_SERVER_IP:5001

# ── Hub identity (used on first registration with central API) ───────────────
HUB_NAME=Lumora Hub
HUB_OWNER_EMAIL=admin@lumora.local
