{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "platforms": ["android", "macOS"],
  "permissions": [
    "core:default",
    "opener:default",
    "notification:default",
    "process:default",
    "process:allow-restart",
    {
      "identifier": "http:default",
      "allow": [{ "url": "https://*.neon.tech/*" }]
    }
  ]
}
