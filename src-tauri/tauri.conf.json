{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "lumora_kiosk",
  "version": "0.1.7",
  "identifier": "com.peakl.lumora-kiosk",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1422",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "lumora_kiosk",
        "fullscreen": true,
        "decorations": false,
        "alwaysOnTop": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "iOS": {
      "developmentTeam": "A8UZ8XDS7R"
    }
  }
}