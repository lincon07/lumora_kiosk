{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "lumora_kiosk",
  "version": "0.1.8",
  "identifier": "com.peakl.lumora-kiosk",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1422",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "lumora_kiosk",
        "fullscreen": true,
        "decorations": false,
        "alwaysOnTop": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri://localhost; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; connect-src 'self' tauri://localhost http://localhost:* ws://localhost:* http://127.0.0.1:* ws://127.0.0.1:* http://0.0.0.0:* ws://0.0.0.0:* http://*.local:* ws://*.local:* https://* wss://*; img-src 'self' https: data: blob:; font-src 'self' data:;"
    }
  },
  "bundle": {
    "createUpdaterArtifacts": true,
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "iOS": {
      "developmentTeam": "A8UZ8XDS7R"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IERDNTNBOEU3NDY1QjAwQkQKUldTOUFGdEc1NmhUM0Z4WTArTTVmVng4L0lMVVQxWlM1eW02S043cUZzUDlIMVgybzBUUmtGaVoK",
      "endpoints": [
        "https://github.com/lincon07/lumora_kiosk/releases/latest/download/latest.json"
      ]
    }
  }
}